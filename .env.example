APP_NAME=SchoolExa
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Pin the cookie name across the L12 -> L13 upgrade. L13 changes the default from
# "<app-slug>_session" to "<app-slug>-session"; leaving this unset logs every user
# out on the upgrade deploy. Keep the pre-upgrade value (APP_NAME slug + _session).
SESSION_COOKIE=schoolexa_session

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# Pin the cache prefix across the L12 -> L13 upgrade (L13 default changes _ -> -),
# otherwise every existing cache key misses on the upgrade deploy.
CACHE_PREFIX=schoolexa_cache_
# If using Redis, also pin REDIS_PREFIX=schoolexa_database_ for the same reason.

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

DATE_FORMAT='Y-m-d'
TIME_FORMAT='H:i:s'
DATETIME_FORMAT='Y-m-d H:i:s'

ENCRYPTION_MASTER_KEY=ZnJhbWV3b3JrL2Jvb3RzdHJhcC8uc3lzX2Jpbl8=

VITE_APP_NAME="${APP_NAME}"
